{
  "name": "nomnomzbot-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "start": "expo start --host lan",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "generate-types": "node -e \"process.env.EXPO_ROUTER_APP_ROOT='./app'; const g=require('@expo/router-server/build/typed-routes/generate'); const t=require('expo-router/internal/testing'); const fs=require('fs'); const ctx=t.requireContext(process.env.EXPO_ROUTER_APP_ROOT,true,/\\\\.[tj]sx?$/); fs.writeFileSync('.expo/types/router.d.ts', g.getTypedRoutesDeclarationFile(ctx,{})); console.log('Generated .expo/types/router.d.ts');\"",
    "test": "jest"
  },
